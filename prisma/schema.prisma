generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

///////////////////#region Tenants
model Tenants {
  id            Int             @id @default(autoincrement())
  username      String
  password      String
  title         String
  nationalCode  String
  entity        String // Enum : Entity
  entity_ref    Int
  allowSharing  Boolean         @default(false)
  created_at    DateTime        @default(now())
  created_by    Int?
  modify_at     DateTime?
  modify_by     Int?
  app_action    Int             @default(1)
  RefreshTokens RefreshTokens[]
  Plans         Plans[]
  Monitorings   Monitorings[]
  Factors       Factors[]
  Orders        Orders[]

  @@map("Tenants")
}

model RefreshTokens {
  id         Int      @id @default(autoincrement())
  token      String   @unique
  tenant     Tenants  @relation(fields: [tenant_ref], references: [id])
  tenant_ref Int
  expires_at DateTime
  created_at DateTime @default(now())
  status     Boolean  @default(true)

  @@map("RefreshTokens")
}

///////////////////#endregion

///////////////////#region Users
model Users {
  id                        Int                         @id @default(autoincrement())
  entityType                String // Enum : EntityType |  نوع موجودیت (مخاطب/اصلی)
  tenant_ref                Int?
  titles                    titles?                     @relation(fields: [title_ref], references: [id], onDelete: NoAction, onUpdate: NoAction)
  title_ref                 Int?
  firstname                 String
  lastname                  String
  gender                    String? // Enum : Gender | جنسیت
  avatar                    String?
  mobile                    String?
  nationalCode              String?
  ecoNumber                 String? // کد اقتصادی
  description               String?
  isCustomer                Boolean                     @default(false)
  profileVersion            Int                         @default(1)
  created_at                DateTime                    @default(now())
  created_by                Int?
  modify_at                 DateTime?
  modify_by                 Int?
  app_action                Int                         @default(1)
  Employees                 Employees[]
  BranchDepartmentEmployees BranchDepartmentEmployees[]

  @@unique([tenant_ref, mobile, entityType, app_action])
  @@unique([tenant_ref, nationalCode, entityType, app_action])
  @@map("Users")
}

///////////////////#endregion

///////////////////#region Companies
model Companies {
  id             Int         @id @default(autoincrement())
  entityType     String // Enum : EntityType |  نوع موجودیت (مخاطب/اصلی)
  tenant_ref     Int?
  titles         titles?     @relation(fields: [title_ref], references: [id], onDelete: NoAction, onUpdate: NoAction)
  title_ref      Int?
  title          String
  nationalCode   String
  logo           String?
  description    String?
  insertNumber   String? // شماره ثبت
  insertDate     String? // تاریخ ثبت
  brand          String? // برند
  shahabCode     String? // کد شهاب
  ecoNumber      String? // کد اقتصادی
  type           String? // Enum : CompanyType | نوع شرکت
  stateType      String? // Enum : CompanyStateType | وضعیت شرکت
  organType      String? // Enum : OrganType | نوع مالکیت شرکت
  isCustomer     Boolean     @default(false)
  profileVersion Int         @default(1)
  created_at     DateTime    @default(now())
  created_by     Int?
  modify_at      DateTime?
  modify_by      Int?
  app_action     Int         @default(1)
  Employees      Employees[]

  @@unique([tenant_ref, nationalCode, entityType, app_action])
  @@unique([tenant_ref, title, entityType, app_action])
  @@map("Companies")
}

///////////////////#endregion

///////////////////#region Branches
model Branches {
  id                   Int                    @id @default(autoincrement())
  tenant_ref           Int?
  entity               String // Enum : Entity |  موجودیت
  entity_ref           Int
  code                 String
  title                String
  bimeh_code           String?
  bimeh_branch         String?
  address              Address?               @relation(fields: [address_ref], references: [id], onDelete: NoAction, onUpdate: NoAction)
  address_ref          Int?
  created_at           DateTime               @default(now())
  created_by           Int
  modify_at            DateTime?
  modify_by            Int?
  app_action           Int                    @default(1)
  branchPhones         BranchPhones[]
  branchBanks          BranchBanks[]
  branchDepartments    BranchDepartments[]
  branchFields         BranchFields[]
  branchModels         BranchModels[]
  BranchSocialAccounts BranchSocialAccounts[]

  @@map("Branches")
}

model BranchFields {
  id                Int            @id @default(autoincrement())
  branches          Branches       @relation(fields: [branch_ref], references: [id])
  branch_ref        Int
  jobFieldTitle     JobFieldTitles @relation(fields: [jobFieldTitle_ref], references: [id])
  jobFieldTitle_ref Int
  created_at        DateTime       @default(now())
  created_by        Int
  modify_at         DateTime?
  modify_by         Int?
  app_action        Int            @default(1)

  @@map("BranchFields")
}

model BranchModels {
  id         Int       @id @default(autoincrement())
  branches   Branches  @relation(fields: [branch_ref], references: [id])
  branch_ref Int
  model      String // Enum : BranchTypeModels | انتخاب مدل
  created_at DateTime  @default(now())
  created_by Int
  modify_at  DateTime?
  modify_by  Int?
  app_action Int       @default(1)

  @@map("BranchModels")
}

model BranchDepartments {
  id                        Int                         @id @default(autoincrement())
  branches                  Branches                    @relation(fields: [branch_ref], references: [id])
  branch_ref                Int
  parent_ref                Int?
  title                     String // عنوان
  created_at                DateTime                    @default(now())
  created_by                Int
  modify_at                 DateTime?
  modify_by                 Int?
  app_action                Int                         @default(1)
  BranchDepartmentEmployees BranchDepartmentEmployees[]

  @@map("BranchDepartments")
}

model BranchPhones {
  id         Int       @id @default(autoincrement())
  branches   Branches  @relation(fields: [branch_ref], references: [id])
  branch_ref Int
  title      String // عنوان
  phone      String // شماره
  type       String // Enum : PhoneTypes | نوع تلفن ها
  operator   String // Enum : PhoneOperators | نوع اپراتور
  created_at DateTime  @default(now())
  created_by Int
  modify_at  DateTime?
  modify_by  Int?
  app_action Int       @default(1)

  @@map("BranchPhones")
}

model BranchBanks {
  id                     Int       @id @default(autoincrement())
  banks                  Banks     @relation(fields: [bank_ref], references: [id])
  bank_ref               Int
  branches               Branches  @relation(fields: [branch_ref], references: [id])
  branch_ref             Int
  bankBranch             String?
  currency               String // Enum : CurrencyTypes | نوع ارز
  type                   String // Enum : BankAccountTypes | نوع حساب
  title                  String // عنوان حساب
  accountNo              String? // شماره حساب
  shabaNo                String? // شماره شبا
  internationalAccountNo String? // شماره حساب بانکی بین‌المللی
  created_at             DateTime  @default(now())
  created_by             Int
  modify_at              DateTime?
  modify_by              Int?
  app_action             Int       @default(1)

  @@map("BranchBanks")
}

model BranchSocialAccounts {
  id         Int       @id @default(autoincrement())
  branches   Branches  @relation(fields: [branch_ref], references: [id])
  branch_ref Int
  address    String
  socialApp  String // Enum : SocialApps | شبکه های اجتماعی
  created_at DateTime  @default(now())
  created_by Int
  modify_at  DateTime?
  modify_by  Int?
  app_action Int       @default(1)

  @@map("BranchSocialAccounts")
}

model BranchDepartmentEmployees {
  id             Int               @id @default(autoincrement())
  department     BranchDepartments @relation(fields: [department_ref], references: [id])
  department_ref Int
  users          Users             @relation(fields: [employee_ref], references: [id])
  employee_ref   Int
  post           String // سمت
  created_at     DateTime          @default(now())
  created_by     Int
  modify_at      DateTime?
  modify_by      Int?
  app_action     Int               @default(1)

  @@map("BranchDepartmentEmployees")
}

model Address {
  id          Int        @id @default(autoincrement())
  cities      Cities?    @relation(fields: [city_ref], references: [id], onDelete: NoAction, onUpdate: NoAction)
  city_ref    Int?
  village     String?
  street      String?
  alley       String?
  alleyNo     String?
  building    String?
  postalCode  String?
  floor       String?
  plate       String?
  description String?
  created_at  DateTime   @default(now())
  created_by  Int
  modify_at   DateTime?
  modify_by   Int?
  app_action  Int        @default(1)
  branches    Branches[]

  @@map("Address")
}

///////////////////#endregion

///////////////////#region Plan
model Plans {
  id         Int       @id @default(autoincrement())
  tenant     Tenants   @relation(fields: [tenant_ref], references: [id])
  tenant_ref Int
  plan_ref   String
  created_at DateTime  @default(now())
  created_by Int?
  modify_at  DateTime?
  modify_by  Int?
  app_action Int       @default(1)

  @@map("Plans")
}

///////////////////#endregion

///////////////////#region Employee
model Employees {
  id          Int       @id @default(autoincrement())
  company     Companies @relation(fields: [company_ref], references: [id])
  company_ref Int
  user        Users     @relation(fields: [user_ref], references: [id])
  user_ref    Int
  created_at  DateTime  @default(now())
  created_by  Int?
  modify_at   DateTime?
  modify_by   Int?
  app_action  Int       @default(1)

  @@map("Employees")
}

///////////////////#endregion

///////////////////#region Monitoring
model Monitorings {
  id         Int       @id @default(autoincrement())
  tenant     Tenants   @relation(fields: [tenant_ref], references: [id])
  tenant_ref Int
  title      String?
  data       String
  created_at DateTime  @default(now())
  created_by Int?
  modify_at  DateTime?
  modify_by  Int?
  app_action Int       @default(1)

  @@map("Monitorings")
}

///////////////////#endregion

///////////////////#region Orders
model Orders {
  id          Int          @id @default(autoincrement())
  from        String // شناسه ملی سفارش دهنده
  to          String // شناسه ملی سفارش گیرنده
  code        Int          @default(0) // شماره سفارش
  from_date   DateTime // تاریخ شروع
  to_date     DateTime // تاریخ پایان
  description String?
  created_at  DateTime     @default(now())
  created_by  Int?
  modify_at   DateTime?
  modify_by   Int?
  app_action  Int          @default(1)
  OrderItems  OrderItems[]
  Tenants     Tenants?     @relation(fields: [tenantsId], references: [id])
  tenantsId   Int?
  Factors     Factors[]

  @@map("orders")
}

model OrderItems {
  id          Int       @id @default(autoincrement())
  order       Orders    @relation(fields: [order_ref], references: [id])
  order_ref   Int
  product     Products  @relation(fields: [product_ref], references: [id])
  product_ref Int // محصول
  code        Int       @default(0) // شماره ردیف سفارش
  count       String // تعداد/وزن
  weightType  String // واحد اندازه گیری
  description String? // توضیحات
  created_at  DateTime  @default(now())
  created_by  Int?
  modify_at   DateTime?
  modify_by   Int?
  app_action  Int       @default(1)

  @@map("orderItems")
}

///////////////////#endregion

///////////////////#region Factors
model Factors {
  id          Int           @id @default(autoincrement())
  parent_ref  Int?
  tenant      Tenants       @relation(fields: [tenant_ref], references: [id])
  tenant_ref  Int
  order       Orders        @relation(fields: [order_ref], references: [id])
  order_ref   Int
  entity      String // Enum : Entity
  entity_ref  Int // مشتری
  factor_type String // Enum : FactorType
  code        Int           @default(0) // شماره فاکتور
  serial      Int           @default(0) // ردیف فاکتور
  date        DateTime
  sign_state  Boolean // دارای امضا
  description String?
  policies    String?
  created_at  DateTime      @default(now())
  created_by  Int?
  modify_at   DateTime?
  modify_by   Int?
  app_action  Int           @default(1)
  FactorItems FactorItems[]

  @@map("factors")
}

model FactorItems {
  id                Int       @id @default(autoincrement())
  factor            Factors   @relation(fields: [factor_ref], references: [id])
  factor_ref        Int
  product           Products  @relation(fields: [product_ref], references: [id])
  product_ref       Int // محصول
  count             String // تعداد/وزن
  weightType        String // واحداندازه گیری
  baseFee           String //قیمت پایه هر واحد
  allFee            String //قیمت کل هر واحد
  discount          String //مبلغ تخفیف
  tax               String //مبلغ مالیات
  sumBeforeDiscount String // جمع قبل از تخفیف
  sumAfterDiscount  String // جمع پس از تخفیف
  sumFinal          String // جمع قابل پرداخت
  description       String? // توضیحات
  created_at        DateTime  @default(now())
  created_by        Int?
  modify_at         DateTime?
  modify_by         Int?
  app_action        Int       @default(1)

  @@map("factorItems")
}

model FactorPolicies {
  id          Int       @id @default(autoincrement())
  text        String
  position    Int       @default(0)
  is_selected Boolean   @default(false)
  created_at  DateTime  @default(now())
  created_by  Int?
  modify_at   DateTime?
  modify_by   Int?
  app_action  Int       @default(1)

  @@map("factorPolicies")
}

///////////////////#endregion

///////////////////#region Chats
model Chats {
  id             Int            @id @default(autoincrement())
  fromTenant_ref Int
  toTenant_ref   Int
  created_at     DateTime       @default(now())
  created_by     Int?
  modify_at      DateTime?
  modify_by      Int?
  app_action     Int            @default(1)
  ChatMessages   ChatMessages[]

  @@map("Chats")
}

model ChatMessages {
  id         Int       @id @default(autoincrement())
  chat       Chats     @relation(fields: [chat_ref], references: [id])
  chat_ref   Int
  message    String?
  file       String?
  created_at DateTime  @default(now())
  created_by Int?
  modify_at  DateTime?
  modify_by  Int?
  app_action Int       @default(1)

  @@map("ChatMessages")
}

///////////////////#endregion

///////////////////#region Products
model Products {
  id          Int           @id @default(autoincrement())
  title       String
  description String?
  properties  String?
  created_at  DateTime      @default(now())
  created_by  Int
  modify_at   DateTime?
  modify_by   Int?
  app_action  Int           @default(1)
  FactorItems FactorItems[]
  OrderItems  OrderItems[]

  @@map("Products")
}

///////////////////#endregion
///////////////////#region Base
model Cities {
  id         Int       @id @default(autoincrement())
  title      String
  type       String // Enum : CityType | نوع موجودیت شهر
  parent_ref Int
  created_at DateTime  @default(now())
  created_by Int
  modify_at  DateTime?
  modify_by  Int?
  app_action Int       @default(1)
  addresses  Address[]

  @@map("Cities")
}

model Banks {
  id          Int           @id @default(autoincrement())
  title       String
  description String
  created_at  DateTime      @default(now())
  created_by  Int
  modify_at   DateTime?
  modify_by   Int?
  app_action  Int           @default(1)
  branchBanks BranchBanks[]

  @@map("Banks")
}

// حوزه های کاری
model JobFieldTitles {
  id           Int            @id @default(autoincrement())
  title        String
  description  String?
  parent_ref   Int?
  created_at   DateTime       @default(now())
  created_by   Int
  modify_at    DateTime?
  modify_by    Int?
  app_action   Int            @default(1)
  BranchFields BranchFields[]

  @@map("JobFieldTitles")
}

// عناوین و القاب
model titles {
  id         Int         @id @default(autoincrement())
  title      String
  gender     String // Enum : Gender | جنسیت
  created_at DateTime    @default(now())
  created_by Int
  modify_at  DateTime?
  modify_by  Int?
  app_action Int         @default(1)
  users      Users[]
  companies  Companies[]

  @@map("titles")
}

///////////////////#endregion
